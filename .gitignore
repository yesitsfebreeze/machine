# --- Claude Code runtime / home state — NEVER track (contains secrets) ---
# NOTE: .claude/ is the MACHINE payload here (tracked). Only home-state dirs
# at the repo root are ignored. Locks and .kern/ are excluded by rules below.
.credentials.json
.claude.json
sessions/
projects/
history.jsonl
cache/
backups/
plugins/

# kern daemon data store (binary LMDB)
.kern/

# mesh daemon data store (LMDB primary + SQLite-WAL journal)
.mesh/

# lock files
*.lock
*.lock.json

# installed-machine version stamp (generated at install/update time, never tracked)
version.log

# --- Claude Code runtime / home state — NEVER track (contains secrets) ---
# NOTE: .claude/ is the MACHINE payload here (tracked). Only home-state dirs
# at the repo root are ignored. Locks and .kern/ are excluded by rules below.
.credentials.json
.claude.json
sessions/
projects/
history.jsonl
cache/
backups/
plugins/

# kern daemon data store (binary LMDB)
.kern/

# mesh daemon data store (LMDB primary + SQLite-WAL journal)
.mesh/

# board addon data store (single JSON state + lock)
.board/

# lock files
*.lock
*.lock.json

# installed-machine version stamp (generated at install/update time, never tracked)
version.log

# --- git-fs companion plugin runtime (per-repo object store, never track) ---
.git-fs/
.agent

# drill orchestrator + miner worktrees (created per session/job, never track)
.machine/worktrees/

# graphify capability graph (generated by scripts/graphify.mjs at pre-push)
.machine/graph.json

# board project identity (resolved per-cwd at runtime via project_resolve)
.machine/board.json

# machine env cache (absolute install paths, written each session by ignite.mjs)
.machine/ENV.md

.env
.env.*

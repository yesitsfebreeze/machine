{
  "mcpServers": {
    "kern": {
      "args": [
        "mcp"
      ],
      "command": "kern"
    },
    "mesh": {
      "args": [
        "mcp"
      ],
      "command": "mesh"
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    },
    "pdf-reader": {
      "command": "npx",
      "args": [
        "-y",
        "@sylphx/pdf-reader-mcp"
      ]
    },
    "git-fs": {
      "command": "git-fs-mcp",
      "env": {
        "GIT_FS_REPO": "${CLAUDE_PROJECT_DIR}/.git-fs"
      }
    }
  }
}

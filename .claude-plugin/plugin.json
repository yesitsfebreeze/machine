{
  "name": "machine",
  "description": "The machine — a portable Claude Code payload: eager-generalist default agent, specialist sub-agents, on-demand skills, lifecycle hooks, output styles, and the hub singleton daemon (coordination, board, mine catalog). Pairs with the kern memory plugin, installed alongside. Specialized per-repo by /oil into /.machine.",
  "version": "0.8.3",
  "author": {
    "name": "yesitsfebreeze",
    "url": "https://github.com/yesitsfebreeze"
  },
  "homepage": "https://github.com/yesitsfebreeze/machine",
  "repository": "https://github.com/yesitsfebreeze/machine.git",
  "keywords": [
    "agents",
    "skills",
    "workflow",
    "memory",
    "kern",
    "hub",
    "code-quality",
    "orchestration"
  ],
  "agents": [
    "./.claude/agents/default.md",
    "./.claude/agents/manager-ddd.md",
    "./.claude/agents/manager-tdd.md",
    "./.claude/agents/drill.md",
    "./.claude/agents/builder-agent.md",
    "./.claude/agents/builder-skill.md",
    "./.claude/agents/builder-plugin.md"
  ],
  "skills": [
    "./.claude/skills/caveman",
    "./.claude/skills/cheat",
    "./.claude/skills/clean",
    "./.claude/skills/coder",
    "./.claude/skills/codex-review",
    "./.claude/skills/drill",
    "./.claude/skills/gate",
    "./.claude/skills/improve",
    "./.claude/skills/mcp-plugin",
    "./.claude/skills/mine",
    "./.claude/skills/oil",
    "./.claude/skills/personas",
    "./.claude/skills/promote",
    "./.claude/skills/questioneer",
    "./.claude/skills/report"
  ],
  "outputStyles": "./.claude/output-styles",
  "hooks": "./.claude/hooks/hooks.json",
  "mcpServers": {
    "hub": {
      "type": "http",
      "url": "http://localhost:7777/mcp"
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY:-}"
      }
    },
    "pdf-reader": {
      "command": "npx",
      "args": [
        "-y",
        "@sylphx/pdf-reader-mcp"
      ]
    },
    "context-mode": {
      "command": "npx",
      "args": [
        "-y",
        "context-mode@latest"
      ]
    }
  }
}

{
  "name": "machine",
  "description": "The machine — a portable Claude Code payload: eager-generalist default agent, specialist sub-agents, on-demand skills, lifecycle hooks, output styles, and the kern memory daemon and mesh coordination daemon. Specialized per-repo by /oil into /.machine.",
  "version": "0.6.1",
  "author": {
    "name": "yesitsfebreeze",
    "url": "https://github.com/yesitsfebreeze"
  },
  "homepage": "https://github.com/yesitsfebreeze/machine",
  "repository": "https://github.com/yesitsfebreeze/machine.git",
  "keywords": [
    "agents",
    "skills",
    "workflow",
    "memory",
    "kern",
    "mesh",
    "code-quality",
    "orchestration"
  ],
  "agents": [
    "./.claude/agents/default.md",
    "./.claude/agents/manager-ddd.md",
    "./.claude/agents/manager-tdd.md",
    "./.claude/agents/drill.md",
    "./.claude/agents/builder-agent.md",
    "./.claude/agents/builder-skill.md",
    "./.claude/agents/builder-plugin.md"
  ],
  "skills": [
    "./.claude/skills/caveman",
    "./.claude/skills/cheat",
    "./.claude/skills/clean",
    "./.claude/skills/coder",
    "./.claude/skills/codex-review",
    "./.claude/skills/drill",
    "./.claude/skills/gate",
    "./.claude/skills/improve",
    "./.claude/skills/mcp-plugin",
    "./.claude/skills/mine",
    "./.claude/skills/oil",
    "./.claude/skills/personas",
    "./.claude/skills/report"
  ],
  "outputStyles": "./.claude/output-styles",
  "hooks": "./.claude/hooks/hooks.json",
  "mcpServers": {
    "kern": {
      "command": "kern",
      "args": [
        "mcp"
      ]
    },
    "mesh": {
      "command": "node",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/mesh/mesh.mjs",
        "mcp"
      ]
    },
    "board": {
      "command": "node",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/board/board.mjs",
        "mcp"
      ]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY:-}"
      }
    },
    "pdf-reader": {
      "command": "npx",
      "args": [
        "-y",
        "@sylphx/pdf-reader-mcp"
      ]
    },
    "context-mode": {
      "command": "npx",
      "args": [
        "-y",
        "context-mode@latest"
      ]
    }
  }
}
